generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== MODELO EMPRESA ==========
model empresa {
  id                   String         @id @default(uuid()) @db.Uuid
  razaoSocial          String         @map("razao_social")
  nomeFantasia         String?        @map("nome_fantasia")
  cnpj                 String         @unique @db.Char(14)
  email                String
  telefone             String?
  celular              String?
  
  // Plano
  plano                String         @default("BASICO")
  limiteFuncionarios   Int            @default(10) @map("limite_funcionarios")
  valorMensal          Float          @default(97.00) @map("valor_mensal")
  diaVencimento        Int            @default(5) @map("dia_vencimento")
  
  // Status
  status               String         @default("TESTE")
  dataCadastro         DateTime       @default(now()) @map("data_cadastro")
  dataExpiracaoTeste   DateTime?      @map("data_expiracao_teste")
  
  // Personalização
  logo                 String?
  corPrimaria          String         @default("#4361ee") @map("cor_primaria")
  corSecundaria        String         @default("#3f37c9") @map("cor_secundaria")
  
  // Relacionamentos
  usuarios             usuario[]
  funcionarios         funcionario[]
  pagamentos           pagamento[]
  registrosPonto       registroPonto[]

  created_at           DateTime       @default(now()) @map("created_at")
  updated_at           DateTime       @updatedAt @map("updated_at")

  @@map("empresas")
}

// ========== MODELO USUÁRIO ==========
model usuario {
  id                     String       @id @default(uuid()) @db.Uuid
  empresaId              String       @map("empresa_id") @db.Uuid
  funcionarioId          String?      @unique @map("funcionario_id") @db.Uuid
  
  nome                   String
  email                  String       @unique
  senha                  String
  telefone               String?
  foto                   String?
  
  tipo                   String       @default("FUNCIONARIO")
  permissoes             Json         @default("{}")
  
  // 2FA
  doisFatoresAtivo       Boolean      @default(false) @map("dois_fatores_ativo")
  segredo2FA             String?      @map("segredo_2fa")
  
  // Controle
  ativo                  Boolean      @default(true)
  ultimoAcesso           DateTime?    @map("ultimo_acesso")
  tentativasLogin        Int          @default(0) @map("tentativas_login")
  bloqueadoAte           DateTime?    @map("bloqueado_ate")
  
  // Relacionamentos
  empresa                empresa      @relation(fields: [empresaId], references: [id])
  funcionario            funcionario? @relation(fields: [funcionarioId], references: [id])

  created_at             DateTime     @default(now()) @map("created_at")
  updated_at             DateTime     @updatedAt @map("updated_at")

  @@map("usuarios")
}

// ========== MODELO FUNCIONÁRIO ==========
model funcionario {
  id                    String       @id @default(uuid()) @db.Uuid
  empresaId             String       @map("empresa_id") @db.Uuid
  
  nome                   String
  cpf                    String       @unique @db.Char(11)
  dataNascimento         DateTime?    @map("data_nascimento") @db.Date
  email                  String
  telefone               String?
  celular                String?
  
  // Profissional
  matricula              String       @unique
  departamento           String?
  cargo                  String?
  dataAdmissao           DateTime?    @map("data_admissao") @db.Date
  dataDemissao           DateTime?    @map("data_demissao") @db.Date
  salario                Float?       @db.Decimal(10,2)
  
  // Biometria
  pinAcesso              String?      @map("pin_acesso") @db.Char(6)
  foto                   String?
  fotosBiometria         Json?        @map("fotos_biometria")
  
  // Status
  status                 String       @default("ATIVO")
  
  // Relacionamentos
  empresa                empresa      @relation(fields: [empresaId], references: [id])
  usuario                usuario?
  registrosPonto         registroPonto[]

  created_at             DateTime     @default(now()) @map("created_at")
  updated_at             DateTime     @updatedAt @map("updated_at")

  @@unique([empresaId, matricula])
  @@map("funcionarios")
}

// ========== MODELO REGISTRO PONTO ==========
model registroPonto {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  funcionarioId   String   @map("funcionario_id") @db.Uuid
  
  tipo            String
  dataHora        DateTime @map("data_hora")
  
  // Geolocalização
  latitude        Float?   @db.Decimal(10,8)
  longitude       Float?   @db.Decimal(11,8)
  
  // Biometria
  foto            String?
  pontuacaoFacial Float?   @map("pontuacao_facial")
  metodo          String?  @default("WEB")
  
  // Validação
  valido          Boolean  @default(true)
  observacao      String?  @db.Text
  
  // Dispositivo
  ip              String?
  dispositivo     String?
  
  // Relacionamentos
  empresa         empresa      @relation(fields: [empresaId], references: [id])
  funcionario     funcionario  @relation(fields: [funcionarioId], references: [id])

  created_at      DateTime     @default(now()) @map("created_at")
  updated_at      DateTime     @updatedAt @map("updated_at")

  @@index([funcionarioId])
  @@index([dataHora])
  @@map("registros_ponto")
}

// ========== MODELO PAGAMENTO ==========
model pagamento {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  
  mes             Int
  ano             Int
  valor           Float    @db.Decimal(10,2)
  dataVencimento  DateTime @map("data_vencimento") @db.Date
  dataPagamento   DateTime? @map("data_pagamento") @db.Date
  status          String   @default("PENDENTE")
  
  // Relacionamentos
  empresa         empresa  @relation(fields: [empresaId], references: [id])

  created_at      DateTime @default(now()) @map("created_at")
  updated_at      DateTime @updatedAt @map("updated_at")

  @@unique([empresaId, mes, ano])
  @@map("pagamentos")
}